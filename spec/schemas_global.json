{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grocery Bot Protocol — GLOBAL Schemas",
  "description": "Shared schemas for all difficulty levels. Level-specific constraints (grid size, bot count, items per order) are in schemas_<level>.json.",
  "scope": "GLOBAL",

  "$defs": {
    "position": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 2,
      "description": "[x, y] — origin (0,0) is top-left, x→right, y→down"
    },

    "bot": {
      "type": "object",
      "properties": {
        "id":        { "type": "integer", "minimum": 0, "description": "Bot identifier (0-indexed)" },
        "position":  { "$ref": "#/$defs/position" },
        "inventory": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3,
          "description": "Items currently held (max 3)"
        }
      },
      "required": ["id", "position", "inventory"],
      "additionalProperties": false
    },

    "item": {
      "type": "object",
      "properties": {
        "id":       { "type": "string", "pattern": "^item_\\d+$" },
        "type":     { "type": "string", "description": "Item type name (e.g. milk)" },
        "position": { "$ref": "#/$defs/position", "description": "Shelf position (not walkable)" }
      },
      "required": ["id", "type", "position"],
      "additionalProperties": false
    },

    "order": {
      "type": "object",
      "properties": {
        "id":              { "type": "string", "pattern": "^order_\\d+$" },
        "items_required":  { "type": "array", "items": { "type": "string" } },
        "items_delivered": { "type": "array", "items": { "type": "string" } },
        "complete":        { "type": "boolean" },
        "status":          { "type": "string", "enum": ["active", "preview"] }
      },
      "required": ["id", "items_required", "items_delivered", "complete", "status"],
      "additionalProperties": false
    },

    "grid": {
      "type": "object",
      "properties": {
        "width":  { "type": "integer" },
        "height": { "type": "integer" },
        "walls":  { "type": "array", "items": { "$ref": "#/$defs/position" } }
      },
      "required": ["width", "height", "walls"],
      "additionalProperties": false
    },

    "action_move": {
      "type": "object",
      "properties": {
        "bot":    { "type": "integer", "minimum": 0 },
        "action": { "type": "string", "enum": ["move_up", "move_down", "move_left", "move_right"] }
      },
      "required": ["bot", "action"],
      "additionalProperties": false
    },

    "action_pick_up": {
      "type": "object",
      "properties": {
        "bot":     { "type": "integer", "minimum": 0 },
        "action":  { "type": "string", "const": "pick_up" },
        "item_id": { "type": "string", "pattern": "^item_\\d+$" }
      },
      "required": ["bot", "action", "item_id"],
      "additionalProperties": false
    },

    "action_drop_off": {
      "type": "object",
      "properties": {
        "bot":    { "type": "integer", "minimum": 0 },
        "action": { "type": "string", "const": "drop_off" }
      },
      "required": ["bot", "action"],
      "additionalProperties": false
    },

    "action_wait": {
      "type": "object",
      "properties": {
        "bot":    { "type": "integer", "minimum": 0 },
        "action": { "type": "string", "const": "wait" }
      },
      "required": ["bot", "action"],
      "additionalProperties": false
    },

    "bot_action": {
      "oneOf": [
        { "$ref": "#/$defs/action_move" },
        { "$ref": "#/$defs/action_pick_up" },
        { "$ref": "#/$defs/action_drop_off" },
        { "$ref": "#/$defs/action_wait" }
      ]
    },

    "game_state": {
      "title": "GameState [GLOBAL]",
      "description": "Server → Client: Full game state, sent each round. Schema is identical across all levels.",
      "type": "object",
      "properties": {
        "type":               { "type": "string", "const": "game_state" },
        "round":              { "type": "integer", "minimum": 0, "maximum": 299 },
        "max_rounds":         { "type": "integer", "const": 300 },
        "grid":               { "$ref": "#/$defs/grid" },
        "bots":               { "type": "array", "items": { "$ref": "#/$defs/bot" }, "minItems": 1, "maxItems": 10 },
        "items":              { "type": "array", "items": { "$ref": "#/$defs/item" } },
        "orders":             { "type": "array", "items": { "$ref": "#/$defs/order" }, "minItems": 1, "maxItems": 2 },
        "drop_off":           { "$ref": "#/$defs/position" },
        "score":              { "type": "integer", "minimum": 0 },
        "active_order_index": { "type": "integer", "minimum": 0 },
        "total_orders":       { "type": "integer", "minimum": 1 }
      },
      "required": ["type", "round", "max_rounds", "grid", "bots", "items", "orders", "drop_off", "score", "active_order_index", "total_orders"],
      "additionalProperties": false
    },

    "game_over": {
      "title": "GameOver [GLOBAL]",
      "description": "Server → Client: Sent once when the game ends.",
      "type": "object",
      "properties": {
        "type":             { "type": "string", "const": "game_over" },
        "score":            { "type": "integer", "minimum": 0 },
        "rounds_used":      { "type": "integer", "minimum": 1, "maximum": 300 },
        "items_delivered":  { "type": "integer", "minimum": 0 },
        "orders_completed": { "type": "integer", "minimum": 0 }
      },
      "required": ["type", "score", "rounds_used", "items_delivered", "orders_completed"],
      "additionalProperties": false
    },

    "bot_response": {
      "title": "BotResponse [GLOBAL]",
      "description": "Client → Server: Actions for all bots. Array length must match bot count for the level.",
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/bot_action" },
          "minItems": 1,
          "maxItems": 10
        }
      },
      "required": ["actions"],
      "additionalProperties": false
    }
  }
}
