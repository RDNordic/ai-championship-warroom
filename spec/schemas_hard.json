{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grocery Bot Protocol — HARD Level Constraints",
  "description": "Level-specific constraints for Hard. All base schemas are in schemas_global.json.",
  "scope": "HARD",

  "level_parameters": {
    "grid_width": 22,
    "grid_height": 14,
    "bot_count": 5,
    "aisles": 4,
    "item_types": 12,
    "items_per_order_min": 3,
    "items_per_order_max": 5
  },

  "$defs": {
    "game_state_hard": {
      "title": "GameState [HARD]",
      "description": "Inherits schemas_global.json#/$defs/game_state with Hard constraints applied.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/game_state" },
        {
          "type": "object",
          "properties": {
            "grid": {
              "type": "object",
              "properties": {
                "width":  { "const": 22 },
                "height": { "const": 14 }
              }
            },
            "bots": {
              "type": "array",
              "minItems": 5,
              "maxItems": 5
            }
          }
        }
      ]
    },

    "bot_response_hard": {
      "title": "BotResponse [HARD]",
      "description": "Inherits schemas_global.json#/$defs/bot_response — exactly 5 actions.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/bot_response" },
        {
          "type": "object",
          "properties": {
            "actions": {
              "minItems": 5,
              "maxItems": 5
            }
          }
        }
      ]
    }
  }
}
