{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grocery Bot Protocol — MEDIUM Level Constraints",
  "description": "Level-specific constraints for Medium. All base schemas are in schemas_global.json.",
  "scope": "MEDIUM",

  "level_parameters": {
    "grid_width": 16,
    "grid_height": 12,
    "bot_count": 3,
    "aisles": 3,
    "item_types": 8,
    "items_per_order_min": 3,
    "items_per_order_max": 5
  },

  "$defs": {
    "game_state_medium": {
      "title": "GameState [MEDIUM]",
      "description": "Inherits schemas_global.json#/$defs/game_state with Medium constraints applied.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/game_state" },
        {
          "type": "object",
          "properties": {
            "grid": {
              "type": "object",
              "properties": {
                "width":  { "const": 16 },
                "height": { "const": 12 }
              }
            },
            "bots": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3
            }
          }
        }
      ]
    },

    "bot_response_medium": {
      "title": "BotResponse [MEDIUM]",
      "description": "Inherits schemas_global.json#/$defs/bot_response — exactly 3 actions.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/bot_response" },
        {
          "type": "object",
          "properties": {
            "actions": {
              "minItems": 3,
              "maxItems": 3
            }
          }
        }
      ]
    }
  }
}
