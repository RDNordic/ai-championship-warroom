{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grocery Bot Protocol — EASY Level Constraints",
  "description": "Level-specific constraints for Easy. All base schemas are in schemas_global.json.",
  "scope": "EASY",

  "level_parameters": {
    "grid_width": 12,
    "grid_height": 10,
    "bot_count": 1,
    "aisles": 2,
    "item_types": 4,
    "items_per_order_min": 3,
    "items_per_order_max": 4
  },

  "$defs": {
    "game_state_easy": {
      "title": "GameState [EASY]",
      "description": "Inherits schemas_global.json#/$defs/game_state with Easy constraints applied.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/game_state" },
        {
          "type": "object",
          "properties": {
            "grid": {
              "type": "object",
              "properties": {
                "width":  { "const": 12 },
                "height": { "const": 10 }
              }
            },
            "bots": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1
            }
          }
        }
      ]
    },

    "bot_response_easy": {
      "title": "BotResponse [EASY]",
      "description": "Inherits schemas_global.json#/$defs/bot_response — exactly 1 action.",
      "allOf": [
        { "$ref": "schemas_global.json#/$defs/bot_response" },
        {
          "type": "object",
          "properties": {
            "actions": {
              "minItems": 1,
              "maxItems": 1
            }
          }
        }
      ]
    }
  }
}
