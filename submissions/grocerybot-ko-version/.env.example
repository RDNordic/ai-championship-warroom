# Get tokens: sign in at dev.ainm.no → Challenge page → pick a map → click Play.
# Paste each JWT token below. NEVER commit a real .env file.

# One token per difficulty level
GROCERY_BOT_TOKEN_EASY=
GROCERY_BOT_TOKEN_MEDIUM=
GROCERY_BOT_TOKEN_HARD=
GROCERY_BOT_TOKEN_EXPERT=

# Optional: override the WebSocket endpoint (default: wss://game-dev.ainm.no/ws)
# GROCERY_BOT_WS_URL=wss://game-dev.ainm.no/ws
